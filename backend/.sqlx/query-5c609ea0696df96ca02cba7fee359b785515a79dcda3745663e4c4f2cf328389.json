  "query": "\n        SELECT\n            usage_path AS \"usage_path!\",\n            kind AS \"kind!: AssetKind\",\n            path AS \"path!\"\n        FROM asset\n        WHERE workspace_id = $1\n          AND usage_kind = 'script'\n          AND usage_access_type IN ('w', 'rw')\n        ",
